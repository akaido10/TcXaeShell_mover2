perty><Name>c++_compatible</Name></Property><Property><Name>external_name</Name><Value>MC_PlanarTrackTrail_GUID_E3A5E3FC_A412_9A03_BBE9_739F2A6B578F</Value></Property><Property><Name>no_explicit_call</Name><Value>do not call this POU directly</Value></Property><Property><Name>no_assign_warning</Name></Property></Properties></DataType><DataType><Name Namespace="Tc3_Mc3PlanarMotion">MC_SYNC_DIRECTIONS</Name><Comment><![CDATA[ Directions in which a slave is allowed to move during synchronizing phase. ]]></Comment><BitSize>16</BitSize><BaseType>UINT</BaseType><EnumInfo><Text>Invalid</Text><Enum>0</Enum><Comment><![CDATA[ Indicates invalid information, e.g. no connection or component not yet ready. ]]></Comment><Properties><Property><Name>hide</Name></Property></Properties></EnumInfo><EnumInfo><Text>Positive</Text><Enum>1</Enum><Comment><![CDATA[ Movement is allowed only in positive direction while synchronizing. ]]></Comment></EnumInfo><EnumInfo><Text>Negative</Text><Enum>2</Enum><Comment><![CDATA[ Movement is allowed only in negative direction while synchronizing. ]]></Comment></EnumInfo><EnumInfo><Text>Both</Text><Enum>3</Enum><Comment><![CDATA[ Movement is allowed in any direction while synchronizing. ]]></Comment></EnumInfo><Properties><Property><Name>qualified_only</Name></Property><Property><Name>to_string</Name></Property></Properties><Default><EnumText>Invalid</EnumText></Default></DataType><DataType><Name Namespace="Tc3_Mc3PlanarMotion" IecLibraryType="true">ST_GearInPosOnTrackWithMasterMoverOptions</Name><Comment><![CDATA[ Options for the "GearInPosOnTrackWithMasterMover" command of the Planar Mover. ]]></Comment><BitSize>448</BitSize><SubItem><Name>gap</Name><Type>LREAL</Type><Comment><![CDATA[ Minimal distance [mm] to next Planar Mover on track. ]]></Comment><BitSize>64</BitSize><BitOffs>0</BitOffs><Default><Value>200</Value></Default></SubItem><SubItem><Name>inSyncToleranceDistance</Name><Type>LREAL</Type><Comment><![CDATA[ Tolerance in absolute value [mm] 