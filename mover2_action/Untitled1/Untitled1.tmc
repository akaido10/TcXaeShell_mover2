in">MC_LREAL</Type><BitSize>64</BitSize><Properties><Property><Name>monitoring</Name><Value>call</Value></Property></Properties></Parameter><Properties><Property><Name>property</Name></Property></Properties></Method><Properties><Property><Name>PouType</Name><Value>FunctionBlock</Value></Property><Property><Name>c++_compatible</Name></Property><Property><Name>external_name</Name><Value>DynamicConstraint_PathXY_GUID_5ECFCC0D_1CF9_EDF1_A171_8BBEE573B5BB</Value></Property><Property><Name>no_explicit_call</Name><Value>do not call this POU directly</Value></Property><Property><Name>no_assign_warning</Name></Property></Properties></DataType><DataType><Name GUID="{51EC8EBA-E260-4EDC-94C0-5ED02ABD2F9A}" Namespace="MC" TcBaseType="true">MC_DYNAMICS_REDUCTION_MODE</Name><Comment><![CDATA[Indicates the way in which dynamics are planned when moving on track.]]></Comment><BitSize>16</BitSize><BaseType GUID="{18071995-0000-0000-0000-000000000005}">UINT</BaseType><EnumInfo><Text><![CDATA[Invalid]]></Text><Enum>0</Enum><Comment><![CDATA[Indicates no or invalid information, e.g. no connection or component not yet ready.]]></Comment></EnumInfo><EnumInfo><Text><![CDATA[None]]></Text><Enum>1</Enum><Comment><![CDATA[The Planar Mover interprets the given dynamic limits in a one-dimensional fashion, with respect to the track's arclength. This way, the maximum velocity is aimed at even in curves.]]></Comment></EnumInfo><EnumInfo><Text><![CDATA[AccelerationLimitedVelocity]]></Text><Enum>2</Enum><Comment><![CDATA[The maximal velocity in curves is reduced to not exceed the maximum x,y radial acceleration there. Produces the same behavior as the None mode when on a straight track.]]></Comment></EnumInfo><Properties><Property><Name>plcAttribute_qualified_only</Name></Property><Property><Name>plcAttribute_to_string</Name></Property></Properties></DataType><DataType><Name GUID="{50FEC5F2-C9A2-49A2-AB32-4764BBA0A649}" Namespace="MC" TcBaseType="true">MC_GAP_MODE_ON_TRACK</Name><Comment><![CDATA[Indicates the way in which gap control is done on track.]]></Comment><BitSize>16</BitSize><BaseType GUID="{18071995-0000-0000-0000-000000000005}">UINT</BaseType><EnumInfo><Text><![CDATA[Invalid]]></Text><Enum>0</Enum><Comment><![CDATA[Indicates no or invalid information, e.g. no connection or component not yet ready.]]></Comment></EnumInfo><EnumInfo><Text><![CDATA[Standard1D]]></Text><Enum>1</Enum><Comment><![CDATA[The Planar Mover keeps a distance to its neighbours on track that is at least the sum of gap and stop distance.]]></Comment></EnumInfo><EnumInfo><Text><![CDATA[Fast1D]]></Text><Enum>2</Enum><Comment><![CDATA[The Planar Mover keeps a distance to its neighbours on track that is at least the gap.]]></Comment></EnumInfo><Properties><Property><Name>plcAttribute_qualified_only</Name></Property><Property><Name>plcAttribute_to_string</Name></Property></Properties></DataType><DataType><Name Namespace="Tc3_Mc3PlanarMotion" IecLibraryType="true">ST_MoveOnTrackOptions</Name><Comment><![CDATA[ Options for the "MoveOnTrack" command of the Planar Mover. ]]></Comment><BitSize>256</BitSize><SubItem><Name>gap</Name><Type>LREAL</Type><Comment><![CDATA[ Minimal distance [mm] to next Planar Mover on track. ]]></Comment><BitSize>64</BitSize><BitOffs>0</BitOffs><Default><Value>200</Value></Default></SubItem><SubItem><Name>direction</Name><Type Namespace="Tc3_Mc3PlanarMotion">MC_DIRECTION</Type><Comment><![CDATA[ Direction in which the target is approached. ]]></Comment><BitSize>16</BitSize><BitOffs>64</BitOffs><Default><EnumText>MC_DIRECTION.mcDirectionNonModulo</EnumText></Default></SubItem><SubItem><Name>additionalTurns</Name><Type>UDINT</Type><Comment><![CDATA[ Addition turns to move in modulo movement (positive or negative). ]]></Comment><BitSize>32</BitSize><BitOffs>96</BitOffs><Default><Value>0</Value></Default></SubItem><SubItem><Name>moduloTolerance</Name><Type>LREAL</Type><Comment><![CDATA[ Tolerance "window" [mm] in modulo movement. ]]></Comment><BitSize>64</BitSize><Bit